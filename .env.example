# Particle Post — Environment Variables
# Copy this file to .env and fill in your values for local development.
# In GitHub Actions, add these as repository secrets (Settings > Secrets > Actions).
# NEVER commit .env to git.

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Optional but recommended
NEWS_API_KEY=your_newsapi_org_key_here
PEXELS_API_KEY=your_pexels_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# GitHub Personal Access Token (needs contents:write on this repo)
# Used by GitHub Actions to push commits — not needed locally.
GH_PAT=your_github_pat_here
