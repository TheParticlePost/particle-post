# Particle Post — Environment Variables
# Copy this file to .env and fill in your values for local development.
# In GitHub Actions, add these as repository secrets (Settings > Secrets > Actions).
# NEVER commit .env to git.

# ─── Core LLM ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Research / News APIs ────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
NEWS_API_KEY=your_newsapi_org_key_here

# ─── Stock photography ───────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
# Unsplash — currently under API review, leave blank until approved
# Get key at: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=

# ─── GitHub tokens ───────────────────────────────────────────────────────
# Used by GitHub Actions to push commits — needs contents:write on this repo.
GH_PAT=your_github_pat_here
# Separate token used to dispatch workflow_dispatch from the admin UI.
GH_WORKFLOW_PAT=your_github_workflow_dispatch_pat_here

# ─── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# New "secret" key format (sb_secret_*) for server-side admin operations.
SUPABASE_SECRET=your_supabase_secret_key_here
# Legacy JWT service-role key — required by pipeline/graphics/uploader.py
# and any other server code that calls Supabase Storage.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_jwt_here

# ─── Email ───────────────────────────────────────────────────────────────
# Resend — transactional email (newsletter, password resets, outreach)
RESEND_API_KEY=your_resend_api_key_here

# ─── Hosting / DNS / CDN ─────────────────────────────────────────────────
# Hostinger — domain DNS management
HOSTINGER_API_TOKEN=your_hostinger_api_token_here
# Vercel — deploy hooks, project configuration
VERCEL_TOKEN=your_vercel_token_here

# ─── Image generation ────────────────────────────────────────────────────
# Google Gemini 2.5 Flash Image — used by lib/covers/ Mode E (background-image)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Higgsfield AI — alternative image generation (not currently wired in)
HIGGSFIELD_ID=your_higgsfield_app_id_here
HIGGSFIELD_SECRET=your_higgsfield_secret_here

# ─── UI tooling ──────────────────────────────────────────────────────────
# 21st.dev Magic — component generation MCP
TWENTYFIRST_DEV_API_KEY=your_21st_dev_api_key_here

# ─── Reddit (Social Media Automation Agent) ──────────────────────────────
# Create app at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=ParticlePost/1.0 by u/your_username
